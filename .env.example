# Copier en .env et remplir. Ne pas committer .env
# Utilisé par docker-compose pour les secrets

DATABASE_PASSWORD=votre_mot_de_passe_postgres
JWT_SECRET=une_cle_longue_aleatoire_min_32_caracteres
MAIL_USERNAME=
MAIL_PASSWORD=
# Stripe (obligatoire pour la création de demande avec paiement)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Profil Spring en production : prod (logs allégés, pas de show-sql)
# SPRING_PROFILES_ACTIVE=prod

# CORS : en production, liste des origines du front (séparées par des virgules)
# Ex. CORS_ALLOWED_ORIGINS=https://app.econsulat.com,https://www.econsulat.com
# CORS_ALLOWED_ORIGINS=

# --- Stockage S3 / MinIO (optionnel : si APP_STORAGE_TYPE=s3)
# APP_STORAGE_TYPE=local
# APP_STORAGE_TYPE=s3
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=econsulat
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_REGION=us-east-1
# S3_PATH_STYLE_ACCESS=true
